{
  "mcpServers": {
    "Forgejo": {
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/scripts/run_forgejo_mcp.ps1"
      ]
    },
    "scanner-manager-dev": {
      "command": "${workspaceFolder}${/}.venv${/}Scripts${/}python.exe",
      "args": ["-m", "dev_mcp.mcp_bridge"],
      "cwd": "${workspaceFolder}",
      "env": {
        "SCANNER_MANAGER_DEV_MCP_HOST": "127.0.0.1",
        "SCANNER_MANAGER_DEV_MCP_PORT": "8765"
      }
    }
  }
}
